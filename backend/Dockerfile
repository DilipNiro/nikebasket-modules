# Instructions à écrire dans l'ordre :
#
#   1. FROM node:20-alpine
#      → utiliser l'image Node.js 20 légère (Alpine Linux)
#
#   2. WORKDIR /app
#      → définir le dossier de travail dans le conteneur
#
#   3. COPY package*.json ./
#      → copier SEULEMENT les fichiers package avant npm install
#      (optimisation : cette couche est mise en cache si package.json n'a pas changé)
#
#   4. RUN npm install
#      → installer les dépendances
#
#   5. COPY . .
#      → copier le reste du code source
#
#   6. EXPOSE 3001
#      → documenter le port exposé
#
#   7. CMD ["npm", "run", "dev"]
#      → commande de démarrage

